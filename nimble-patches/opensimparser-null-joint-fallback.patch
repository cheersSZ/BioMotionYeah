-  assert(childBody != nullptr);
+  // BioMotion patch (iOS release-safety):
+  //
+  // In release builds `assert()` is a no-op, so any path above that uses
+  // `assert(false && "Unsupported number of DOFs in CustomJoint")` or
+  // `assert(false && "Unrecognized function type")` silently falls through
+  // with `joint == nullptr`. The original code then hits
+  // `joint->setName(...)` and segfaults at `this + 0x3f`.
+  //
+  // This block logs the offending joint name + type (so we can pinpoint
+  // which XML entry nimble choked on) and substitutes a WeldJoint in place
+  // so the rest of parseOsim can finish building the skeleton. The affected
+  // joint becomes immobile but the hierarchy stays valid, and any downstream
+  // muscle that references it via body names still resolves.
+  if (joint == nullptr)
+  {
+    std::cerr << "OpenSimParser: failed to construct joint \"" << jointName
+              << "\" of type \"" << jointType
+              << "\" (unsupported CustomJoint DOF or function configuration). "
+              << "Falling back to a WeldJoint so the skeleton parse can continue."
+              << std::endl;
+    dynamics::WeldJoint::Properties props;
+    props.mName = jointName;
+    if (parentBody == nullptr)
+    {
+      auto pair = skel->createJointAndBodyNodePair<dynamics::WeldJoint>(
+          nullptr, props, bodyProps);
+      joint = pair.first;
+      childBody = pair.second;
+    }
+    else
+    {
+      auto pair
+          = parentBody->createChildJointAndBodyNodePair<dynamics::WeldJoint>(
+              props, bodyProps);
+      joint = pair.first;
+      childBody = pair.second;
+    }
+  }
+
+  if (childBody == nullptr)
+  {
+    std::cerr << "OpenSimParser: joint \"" << jointName
+              << "\" created but childBody is null — this indicates a "
+                 "nimble-internal bug, returning partial result."
+              << std::endl;
+    return std::make_tuple(joint, (dynamics::BodyNode*)nullptr,
+                           Eigen::Vector3s::Zero());
+  }
+
   joint->setName(jointName);
